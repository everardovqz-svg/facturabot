# ─── Telegram ───────────────────────────────────────────────
# Obtenlo hablando con @BotFather en Telegram → /newbot
TELEGRAM_TOKEN=tu_token_aqui

# ─── Anthropic (Claude) ──────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Supabase ────────────────────────────────────────────────
# https://supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# ─── Cloudflare R2 ───────────────────────────────────────────
# https://dash.cloudflare.com → R2 → tu bucket → Manage R2 API tokens
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key
R2_SECRET_ACCESS_KEY=tu_secret_key
R2_BUCKET_NAME=recibos-facturacion
R2_PUBLIC_URL=https://tu-bucket.r2.dev

# ─── App ─────────────────────────────────────────────────────
# Cambia en producción por algo seguro: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_algo_seguro
# URL pública de tu servidor (Railway te la da al hacer deploy)
APP_URL=https://tu-app.railway.app
